# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/healthcare_db

# JWT
JWT_SECRET=your_min_32_character_secret_here_change_me
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Email
# Options: mailtrap | resend | ses
EMAIL_PROVIDER=mailtrap
EMAIL_USER=your_mailtrap_username
EMAIL_PASS=your_mailtrap_password
EMAIL_FROM=noreply@healthcare.dev

# Resend (EMAIL_PROVIDER=resend)
# EMAIL_PASS=re_your_resend_api_key

# AWS SES (EMAIL_PROVIDER=ses)
# EMAIL_USER=AKIAIOSFODNN7EXAMPLE
# EMAIL_PASS=your_ses_smtp_password
# AWS_REGION=us-east-1

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200
